EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_AI_EDGE_FUNCTION_URL=https://your-project-ref.functions.supabase.co/score-entry
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_public_sdk_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_public_sdk_key
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_IOS_BUNDLE_ID=com.dialedself.app
EXPO_PUBLIC_ANDROID_PACKAGE=com.dialedself.app
