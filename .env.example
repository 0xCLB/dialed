# Supabase Edge Function secrets, never exposed to the Expo client:
OPENAI_API_KEY=sk-server-only
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role
REVENUECAT_WEBHOOK_AUTH=shared-secret-from-revenuecat
